{
  "name": "quotation-automation",
  "version": "1.0.0",
  "description": "Quotation Automation with OpenAI Integration",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "node tools/e2e-smoke.mjs"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "testTimeout": 15000
  },
  "keywords": [
    "quotation",
    "automation",
    "openai"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.985.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/lib-dynamodb": "^3.985.0",
    "@google-cloud/storage": "^7.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.20.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "playwright": "^1.49.1",
    "supertest": "^7.2.2"
  }
}
